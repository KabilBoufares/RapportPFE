@startuml
' ==================================================
' Diagramme de classes — Billetterie, commandes,
' remboursements et revente
' Version finale UI corrigée
' ==================================================

hide circle
skinparam shadowing false
skinparam linetype ortho
skinparam dpi 300
skinparam roundcorner 6
skinparam classAttributeIconSize 0

scale 0.80

skinparam defaultFontName "Verdana"
skinparam defaultFontSize 12

skinparam ArrowThickness 1.1
skinparam ArrowFontSize 7
skinparam nodesep 44
skinparam ranksep 42

<style>
classDiagram {
  class {
    BackGroundColor #FFFFFF
    LineColor #6C8EBF
    LineThickness 1.4
    FontColor #000000
    FontName "Verdana"
    FontSize 11
    Padding 5
    Margin 2
  }

  note {
    BackGroundColor #FFF9C4
    LineColor #B8A000
    FontColor #000000
    FontName "Verdana"
    FontSize 11
    Padding 5
    Margin 2
  }

  arrow {
    LineColor #6C8EBF
    LineThickness 1.1
    FontColor #000000
    FontName "Verdana"
    FontSize 7
  }
}
</style>

skinparam class {
  BackgroundColor          #FFFFFF
  BorderColor              #6C8EBF
  BorderThickness          1.4
  HeaderBackgroundColor    #DAE8FC
  FontColor                #000000
  FontStyle                Bold
  AttributeFontColor       #000000
  AttributeFontStyle       Plain
  ArrowColor               #6C8EBF
  StereotypeFontColor      #000000
}

skinparam note {
  BackgroundColor          #FFF9C4
  BorderColor              #B8A000
  FontColor                #000000
}

' ==================================================
' ENTITÉS PRINCIPALES
' ==================================================

class Utilisateur {
- id                  : Long
- nomComplet          : String
- email               : String
- motDePasseHache     : String
- numeroTelephone     : String
- bio                 : String
- photoProfil         : String
- pays                : String
- ville               : String
- emailVerifie        : Boolean
- telephoneVerifie    : Boolean
- statutCompte        : StatutCompte
- dateCreation        : DateTime
- dateModification    : DateTime
- statutPartenaire    : PartnerStatus
--
+ consulterTickets()
+ reserverBillet()
+ demanderRemboursement()
+ mettreTicketEnRevente()
}

class Evenement {
- id                      : Long
- titre                   : String
- description             : String
- imageCouverture         : String
- dateDebut               : DateTime
- dateFin                 : DateTime
- lieu                    : String
- adresse                 : String
- ville                   : String
- pays                    : String
- capaciteMax             : Integer
- statut                  : EventStatus
- statutModeration        : ModerationStatus
- typeBilletterie         : TicketingType
- lienBilletterieExterne  : String
--
+ consulterDetails()
}

class TicketType {
- id                    : Long
- nom                   : String
- description           : String
- prix                  : Decimal
- devise                : String
- quantiteTotale        : Integer
- quantiteDisponible    : Integer
- quantiteVendue        : Integer
- maxParUtilisateur     : Integer
- dateDebutVente        : DateTime
- dateFinVente          : DateTime
- actif                 : Boolean
}

class TicketReservation {
- id              : Long
- quantite        : Integer
- statut          : ReservationStatus
- dateExpiration  : DateTime
- version         : Long
--
+ expirer()
+ convertir()
+ annuler()
}

class UserOrder {
- id              : Long
- statut          : OrderStatus
- typeCommande    : OrderType
- sousTotal       : Decimal
- fraisService    : Decimal
- montantTaxe     : Decimal
- montantTotal    : Decimal
- devise          : String
- lienExterne     : String
--
+ confirmerPaiement()
+ marquerEchec()
}

class Payment {
- id                     : Long
- montant                : Decimal
- devise                 : String
- statut                 : PaymentStatus
- stripePaymentIntentId  : String
- stripeChargeId         : String
- stripeTransferId       : String
- stripeRefundId         : String
--
+ confirmer()
+ rembourser()
}

class Ticket {
- id                       : Long
- statut                   : TicketStatus
- codeTicket               : String
- dateEmission             : DateTime
- titreEvenementSnapshot   : String
- dateEvenementSnapshot    : DateTime
- lieuSnapshot             : String
- nomParticipantSnapshot   : String
- montantTotalSnapshot     : Decimal
--
+ afficher()
+ telecharger()
+ transferer()
}

class RefundRequest {
- id            : Long
- raison        : RefundReason
- note          : String
- statut        : RefundStatus
- dateDemande   : DateTime
- dateDecision  : DateTime
--
+ soumettre()
+ approuver()
+ rejeter()
}

class ResaleListing {
- id               : Long
- prixRevente      : Decimal
- fraisPlateforme  : Decimal
- statut           : ResaleStatus
- datePublication  : DateTime
- dateVente        : DateTime
--
+ publier()
+ annuler()
+ vendre()
}

class ExternalTicketListing {
- id                : Long
- titreEvenement    : String
- dateEvenement     : DateTime
- lieu              : String
- prixVente         : Decimal
- imageTicketUrl    : String
- statut            : ExternalListingStatus
- statutEscrow      : EscrowStatus
- datePublication   : DateTime
--
+ publier()
+ annuler()
+ marquerVendue()
}

' ==================================================
' ORGANISATION VISUELLE
' ==================================================

together {
  class Evenement
  class TicketType
  class TicketReservation
}

together {
  class Utilisateur
  class UserOrder
  class Payment
}

together {
  class Ticket
  class RefundRequest
}

together {
  class ResaleListing
  class ExternalTicketListing
}

' Liens invisibles pour stabiliser le placement
Evenement -[hidden]down- TicketType
TicketType -[hidden]down- TicketReservation

Utilisateur -[hidden]down- UserOrder
UserOrder -[hidden]down- Payment

TicketReservation -[hidden]right- Utilisateur
Utilisateur -[hidden]right- TicketReservation

UserOrder -[hidden]right- Ticket
Ticket -[hidden]right- RefundRequest

Ticket -[hidden]down- ResaleListing
ResaleListing -[hidden]right- ExternalTicketListing

' ==================================================
' RELATIONS UTILISATEUR
' ==================================================

Utilisateur "1" -right- "0..*" TicketReservation     : effectue
Utilisateur "1" -down-  "0..*" UserOrder             : passe
Utilisateur "1" -right- "0..*" Ticket                : possède
Utilisateur "1" -down-  "0..*" RefundRequest         : demande
Utilisateur "1" -down-  "0..*" ResaleListing         : publie
Utilisateur "1" -right- "0..*" ExternalTicketListing : propose

' ==================================================
' RELATIONS ÉVÉNEMENT & TYPES DE TICKETS
' ==================================================

Evenement  "1" -down- "0..*" TicketType        : propose
TicketType "1" -down- "0..*" TicketReservation : concerne
TicketType "1" -down- "0..*" Ticket            : définit

' ==================================================
' RELATIONS COMMANDE & PAIEMENT
' ==================================================

TicketReservation "1" -down- "0..1" UserOrder      : convertie en
UserOrder         "1" -down- "0..1" Payment        : est réglée par
UserOrder         "1" -right- "0..*" Ticket        : génère
UserOrder         "1" -right- "0..*" RefundRequest : concerne

' ==================================================
' RELATIONS REVENTE
' ==================================================

Ticket    "1"    -down- "0..1" ResaleListing         : mis en revente
Evenement "1"    -down- "0..*" ResaleListing         : concerne
Evenement "0..1" -down- "0..*" ExternalTicketListing : associé à

' ==================================================
' NOTES DÉSACTIVÉES
' ==================================================

' note right of TicketReservation
' La réservation bloque temporairement
' la disponibilité du billet avant paiement.
'
' Si le paiement n'est pas confirmé
' dans le délai, elle expire et le stock
' est libéré.
' end note

' note right of ExternalTicketListing
' Cette classe représente une extension
' du marché de revente pour les tickets
' externes.
'
' L'utilisateur ajoute une image justificative.
' La transaction peut être sécurisée par escrow,
' sans détailler le litige dans ce diagramme.
' end note

@enduml