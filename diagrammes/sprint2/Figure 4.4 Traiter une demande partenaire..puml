@startuml
actor Administrateur
boundary "Interface d'administration" as AdminUI
control "Back-End FESTY" as Backend
database "Base de données" as DB

autonumber

' Étape 1 – Consultation de la liste des demandes
Administrateur -> AdminUI : Demander la liste des demandes partenaires
activate AdminUI
AdminUI -> Backend : Demander la liste des demandes
deactivate AdminUI

activate Backend
Backend -> DB : Récupérer les demandes partenaires
deactivate Backend

activate DB
DB --> Backend : Liste des demandes
deactivate DB

activate Backend
Backend --> AdminUI : Envoyer la liste
deactivate Backend

activate AdminUI
AdminUI --> Administrateur : Afficher la liste des demandes
deactivate AdminUI

' Étape 2 – Sélection d'une demande
Administrateur -> AdminUI : Sélectionner une demande à traiter
activate AdminUI
AdminUI -> Backend : Demander le détail de la demande
deactivate AdminUI

activate Backend
Backend -> DB : Récupérer les informations et documents
deactivate Backend

activate DB
DB --> Backend : Détail de la demande
deactivate DB

activate Backend
Backend --> AdminUI : Envoyer le détail
deactivate Backend

activate AdminUI
AdminUI --> Administrateur : Afficher les informations et documents
deactivate AdminUI

' Étape 4 – Vérification du dossier par l'administrateur
Administrateur -> AdminUI : Examiner le dossier

alt dossier incomplet (E1)
    ' L'administrateur demande des informations complémentaires
    Administrateur -> AdminUI : Demander des informations complémentaires
    activate AdminUI
    AdminUI -> Backend : Signaler la demande de compléments
    deactivate AdminUI

    activate Backend
    Backend -> DB : Mettre à jour le statut (en attente de compléments)
    deactivate Backend

    activate DB
    DB --> Backend : Confirmation
    deactivate DB

    activate Backend
    Backend --> AdminUI : Confirmation
    deactivate Backend

    activate AdminUI
    AdminUI --> Administrateur : Afficher "Demande de compléments envoyée"
    deactivate AdminUI
else dossier complet
    ' Étape 5 – Décision (accepter ou refuser)
    Administrateur -> AdminUI : Accepter ou refuser la demande
    activate AdminUI
    AdminUI -> Backend : Envoyer la décision (acceptée/refusée)
    deactivate AdminUI

    activate Backend
    Backend -> DB : Mettre à jour le statut (acceptée/refusée)
    deactivate Backend

    activate DB
    DB --> Backend : Confirmation
    deactivate DB

    activate Backend
    Backend --> AdminUI : Confirmation
    deactivate Backend

    activate AdminUI
    AdminUI --> Administrateur : Afficher "Statut mis à jour"
    deactivate AdminUI
end
@enduml