@startuml
actor Partenaire
boundary "Interface partenaire" as PartnerUI
control "Back-End FESTY" as Backend
database "Base de données" as DB
participant "Service de stockage" as Storage

autonumber

' Étape 1 – Accès au formulaire
Partenaire -> PartnerUI : Demander le formulaire de création d'événement
activate PartnerUI
PartnerUI --> Partenaire : Afficher le formulaire
deactivate PartnerUI

' Étapes 2-3 – Saisie des informations et ajout des médias
Partenaire -> PartnerUI : Saisir les informations principales et ajouter les médias
activate PartnerUI

' Possibilité d’annulation avant soumission (E2)
alt partenaire annule l'opération (E2)
    Partenaire -> PartnerUI : Annuler l'opération
    PartnerUI --> Partenaire : Fin de l'interaction
    deactivate PartnerUI
else partenaire soumet l'événement
    Partenaire -> PartnerUI : Soumettre l'événement
    PartnerUI -> Backend : Envoyer les données (informations, médias)
    deactivate PartnerUI

    activate Backend
    Backend -> Backend : Valider les données saisies

    alt données invalides (E1)
        Backend --> PartnerUI : Message d'erreur (E1)
        deactivate Backend
        activate PartnerUI
        PartnerUI --> Partenaire : Afficher "Informations invalides"
        deactivate PartnerUI
    else données valides
        Backend -> Storage : Stocker les médias
        deactivate Backend
        activate Storage
        Storage --> Backend : Confirmation de stockage
        deactivate Storage

        activate Backend
        Backend -> DB : Enregistrer l’événement (statut : en attente de validation)
        deactivate Backend
        activate DB
        DB --> Backend : Confirmation d'enregistrement
        deactivate DB

        activate Backend
        Backend --> PartnerUI : Message de confirmation
        deactivate Backend
        activate PartnerUI
        PartnerUI --> Partenaire : Afficher "Événement soumis avec succès"
        deactivate PartnerUI
    end
end
@enduml