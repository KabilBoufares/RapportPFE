@startuml
actor Utilisateur
boundary "Application mobile" as App
control "Back-End FESTY" as Backend
database "Base de données" as DB

autonumber

' Étape 1 – Accès au profil
Utilisateur -> App : Accéder à la page de profil
activate App
App -> Backend : Demander les informations du profil
deactivate App

activate Backend
Backend -> DB : Récupérer les informations du profil
deactivate Backend

activate DB
DB --> Backend : Informations du profil
deactivate DB

activate Backend
Backend --> App : Envoyer les données du profil
deactivate Backend

activate App
App --> Utilisateur : Afficher les informations du profil
deactivate App

alt quitter sans enregistrer
    Utilisateur -> App : Quitter la page sans enregistrer
    activate App
    App --> Utilisateur : Fin de l'interaction
    deactivate App
else modifier les informations
    Utilisateur -> App : Modifier les informations souhaitées
    activate App
    Utilisateur -> App : Soumettre les modifications
    App -> Backend : Envoyer les nouvelles données
    deactivate App

    activate Backend
    Backend -> Backend : Valider les données saisies

    alt données invalides
        Backend --> App : Message d'erreur (E1)
        deactivate Backend
        activate App
        App --> Utilisateur : Afficher "Données invalides"
        deactivate App
    else données valides
        Backend -> DB : Mettre à jour les informations du profil
        deactivate Backend
        activate DB
        DB --> Backend : Confirmation de mise à jour
        deactivate DB
        activate Backend
        Backend --> App : Message de confirmation
        deactivate Backend
        activate App
        App --> Utilisateur : Afficher "Profil mis à jour avec succès"
        deactivate App
    end
end
@enduml